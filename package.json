{
  "name": "library",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.0",
    "config": "^4.4.1",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "node-pg-migrate": "^8.0.4"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "start": "bun src/index.ts",
    "migrate": "node-pg-migrate -j ts",
    "migrate:create": "bun run migrate create",
    "migrate:up": "bun run migrate up",
    "migrate:down": "bun run migrate down"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/postgres": "^6.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "fastify": "^5.7.4",
    "jwks-rsa": "^3.2.2",
    "pg": "^8.19.0",
    "postgres": "^3.4.8",
    "sanitize-html": "^2.17.1",
    "zod": "^4.3.6"
  }
}
